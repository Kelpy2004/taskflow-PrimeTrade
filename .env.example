# TaskForge environment variables (Next.js + Prisma)

# PostgreSQL connection string.
# Local:  postgresql://taskforge:taskforge@localhost:5432/taskforge?schema=public
# Neon:   postgresql://USER:PASSWORD@HOST/DB?sslmode=require
DATABASE_URL=

# Direct (non-pooled) connection used by Prisma migrations.
# For local Postgres, use the same value as DATABASE_URL.
# For Neon, remove "-pooler" from the host.
DIRECT_URL=

# Secret used to sign JWTs. Use a long random string in production.
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d
